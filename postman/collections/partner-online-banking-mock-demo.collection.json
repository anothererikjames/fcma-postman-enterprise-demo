{
  "info": {
    "_postman_id": "d3a1c0de-2002-4f2a-9b3c-fcmademo0002",
    "name": "Partner Online Banking API - Mock Demo",
    "description": "Demonstrates Postman mock servers for third-party integration development (demo). Saved examples cover the happy path plus edge cases that are hard to force against a real partner sandbox: 503 partner outage, 401 auth failure, malformed 200 payload, and a 422 business-rule failure. Create a mock server from this collection, then point the local-dev-partner-mock environment's baseUrl at the generated mock URL. Mock servers do not replace real partner integration testing, Playwright, Checkly, or FCMA's CI/CD — they accelerate the inner loop. All data is fake demo-only.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get OAuth Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Response is valid JSON\", function () {",
              "    pm.response.to.be.json;",
              "});",
              "",
              "if (pm.response.code >= 400) {",
              "    pm.test(\"Error response includes correlationId\", function () {",
              "        var json = pm.response.json();",
              "        pm.expect(json.correlationId).to.exist;",
              "    });",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-Correlation-Id",
            "value": "{{$guid}}"
          },
          {
            "key": "Content-Type",
            "value": "application/x-www-form-urlencoded"
          }
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "grant_type",
              "value": "client_credentials"
            },
            {
              "key": "client_id",
              "value": "{{partnerClientId}}"
            },
            {
              "key": "client_secret",
              "value": "{{partnerClientSecret}}"
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/oauth/token",
          "host": ["{{baseUrl}}"],
          "path": ["oauth", "token"]
        },
        "description": "Exchanges demo client credentials for a demo access token."
      },
      "response": [
        {
          "name": "auth-token-200",
          "originalRequest": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "client_credentials"
                },
                {
                  "key": "client_id",
                  "value": "demo-client-id"
                },
                {
                  "key": "client_secret",
                  "value": "demo-client-secret"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/oauth/token",
              "host": ["{{baseUrl}}"],
              "path": ["oauth", "token"]
            }
          },
          "status": "OK",
          "code": 200,
          "_postman_previewlanguage": "json",
          "header": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": "{\"accessToken\":\"demo-access-token\",\"tokenType\":\"Bearer\",\"expiresIn\":3600}"
        },
        {
          "name": "auth-failure-401",
          "originalRequest": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              },
              {
                "key": "x-mock-response-code",
                "value": "401"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "client_credentials"
                },
                {
                  "key": "client_id",
                  "value": "demo-client-id"
                },
                {
                  "key": "client_secret",
                  "value": "bad-secret"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/oauth/token",
              "host": ["{{baseUrl}}"],
              "path": ["oauth", "token"]
            }
          },
          "status": "Unauthorized",
          "code": 401,
          "_postman_previewlanguage": "json",
          "header": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": "{\"errorCode\":\"INVALID_TOKEN\",\"message\":\"The access token is expired or invalid.\",\"correlationId\":\"demo-corr-401\"}"
        }
      ]
    },
